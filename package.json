{
  "name": "email-alias-service",
  "version": "1.0.3",
  "description": "Gmail email alias service similar to Hide My Email",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm ci && VITE_GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID npm run build && cd .. && mkdir -p public && cp -r frontend/dist/* public/",
    "build:backend": "tsc",
    "start": "node dist/server.js",
    "postinstall": "npm run build",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^4.13.23",
    "@clerk/express": "^1.7.42",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.6.5",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "redis": "^5.8.3",
    "resend": "^6.2.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
