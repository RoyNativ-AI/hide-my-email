PORT=4887
NODE_ENV=development

# Database (Optional - using memory store by default)
DATABASE_URL=postgresql://username:password@localhost:5432/email_alias

# Clerk Authentication
# Development: pk_test_... / sk_test_...
# Production: pk_live_... / sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_your_production_publishable_key
CLERK_SECRET_KEY=sk_live_your_production_secret_key

# Your domain for aliases
ALIAS_DOMAIN=alias.yourdomain.com

# Frontend URL
FRONTEND_URL=http://localhost:3001

# Cloudflare Email Worker API Key
# Generate a secure random key: openssl rand -hex 32
WORKER_API_KEY=your-secure-random-api-key-here